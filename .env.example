# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram ID администратора (можно получить через @userinfobot)
ADMIN_TELEGRAM_ID=your_telegram_id

# Секретный ключ для Flask веб-админки
FLASK_SECRET_KEY=your-secret-key-change-in-production

# Логин администратора для веб-админки
ADMIN_NAME=admin

# Пароль администратора для веб-админки
ADMIN_PASSWORD=admin_password

# URL Mini App (после деплоя на Vercel)
# S1_WEBAPP_URL=https://your-app.vercel.app
